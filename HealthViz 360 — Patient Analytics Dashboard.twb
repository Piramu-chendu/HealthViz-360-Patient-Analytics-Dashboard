        <calculation class='tableau' formula='IF CONTAINS(LOWER([DESCRIPTION]), &quot;emergency&quot;) THEN &quot;Emergency&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;outpatient&quot;) THEN &quot;Outpatient&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;inpatient&quot;) THEN &quot;Inpatient&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;hospital&quot;) THEN &quot;Inpatient&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;admission&quot;) THEN &quot;Inpatient&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;wellness&quot;) THEN &quot;Wellness&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;office&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;consultation&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;follow&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;encounter&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;prenatal&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;patient&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;domiciliary&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;drug&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;allerg&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;non-urgent&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;obstetric&quot;) THEN &quot;Emergency&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;death&quot;) THEN &quot;Inpatient&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;asthma&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([DESCRIPTION]), &quot;rehab&quot;) THEN &quot;Ambulatory&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
